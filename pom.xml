    /**
     * NCES IPEDS veritabanı.
     * Geçici 'sid' yerine ASP.NET Viewstate yönetimiyle dinamik POST atar.
     */
    public List<Map<String, String>> fetchIpedsData(String institutionName) {
        List<Map<String, String>> ipedsData = new ArrayList<>();
        String baseUrl = "https://nces.ed.gov/ipeds/datacenter/InstitutionByName.aspx";
        
        try {
            // 1. Ana sayfadan Session başlat ve Viewstate'i al
            Connection.Response initialResponse = Jsoup.connect(baseUrl)
                                                       .userAgent(USER_AGENT)
                                                       .method(Connection.Method.GET)
                                                       .execute();
            
            Document initialDoc = initialResponse.parse();
            Element viewStateElem = initialDoc.selectFirst("input[name=__VIEWSTATE]");
            String viewState = (viewStateElem != null) ? viewStateElem.attr("value") : "";
            
            // 2. Spesifik üniversite için formu simüle edip POST at (Session ID zaman aşımını atlatmak için)
            /*
            Document dataDoc = Jsoup.connect(baseUrl)
                                    .userAgent(USER_AGENT)
                                    .cookies(initialResponse.cookies()) // Oturumu koru
                                    .data("__VIEWSTATE", viewState)
                                    .data("ctl00$contentPlaceHolder$txtInstitutionName", institutionName)
                                    // Gerekli diğer form parametreleri buraya eklenecek
                                    .post();
            */
            
        } catch (IOException e) {
            System.err.println("IPEDS verileri çekilirken hata oluştu: " + e.getMessage());
        }
        
        return ipedsData;
    }

